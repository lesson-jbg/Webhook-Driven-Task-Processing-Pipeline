{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "es2019",
    "module": "commonjs",
    "moduleResolution": "node",

    "strict": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": false,

    "types": ["node"],
    "sourceMap": true,
    "skipLibCheck": true
  },
  "exclude": ["drizzle.config.ts", "node_modules"]
}
